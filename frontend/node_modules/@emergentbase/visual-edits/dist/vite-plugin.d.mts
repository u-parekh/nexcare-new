import { Plugin } from 'vite';

interface VisualEditsViteOptions {
    /** Override automatic dev detection. Default: true only in serve mode */
    enable?: boolean;
    /** Tailwind CDN URL passed to the HTML injection. Default: "https://cdn.tailwindcss.com" */
    tailwindCdn?: string | false;
}
/**
 * Vite plugin that adds visual editing capabilities.
 *
 * Automatically:
 * 1. Runs the babel metadata plugin on JSX/TSX files (dev only)
 * 2. Injects the iframe-guard <script> into HTML
 * 3. Serves the visual-edit-overlay.js IIFE
 * 4. Registers dev server middleware (/ping, /edit-file)
 */
declare function visualEdits(options?: VisualEditsViteOptions): Plugin;

export { type VisualEditsViteOptions, visualEdits as default, visualEdits };
